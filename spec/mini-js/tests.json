    "expected_error": "missing '}'"
  },
  {
    "name": "keyword_boundary",
    "description": "%word prevents 'let' from matching prefix of 'letter'",
    "input": "let letter = 1;",
    "expected_vars": { "letter": 1 }
  },
  {
    "name": "modulo_operator",
    "input": "let x = 10 % 3;",
    "expected_vars": { "x": 1 }
  },
  {
    "name": "deeply_nested_expression",
    "input": "let x = ((((1 + 2) * 3) - 4) / 5);",
    "expected_vars": { "x": 1 }
  },
  {
    "name": "empty_function",
    "input": "function noop() {} noop();",
