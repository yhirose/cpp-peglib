[
  {
    "name": "trace_macro_is_transparent",
    "description": "A macro rule fires no enter/leave; only the expanded body's rules do.",
    "grammar": "S <- Rep(A)\nRep(X) <- X+\nA <- < 'a' >\n",
    "trace": {
      "rules": [
        "S",
        "Rep",
        "A"
      ],
      "events": [
        "enter",
        "leave"
      ]
    },
    "cases": [
      {
        "input": "aa",
        "match": true,
        "expected_trace": [
          "enter_S",
          "enter_A",
          "leave_A",
          "enter_A",
          "leave_A",
          "enter_A",
          "leave_A",
          "leave_S"
        ]
      },
      {
        "input": "a",
        "match": true,
        "expected_trace": [
          "enter_S",
          "enter_A",
          "leave_A",
          "enter_A",
          "leave_A",
          "leave_S"
        ]
      }
    ]
  },
  {
    "name": "trace_backtracking_alternatives",
