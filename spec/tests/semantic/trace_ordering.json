    "grammar": "S <- A 'x' / A 'y'\nA <- < 'a' >\n",
    "trace": {
      "rules": [
        "S",
        "A"
      ],
      "events": [
        "enter",
        "leave"
      ]
    },
    "cases": [
      {
        "input": "ax",
        "match": true,
        "expected_trace": [
          "enter_S",
          "enter_A",
          "leave_A",
          "leave_S"
        ]
      },
      {
        "input": "ay",
        "match": true,
        "expected_trace": [
          "enter_S",
          "enter_A",
          "leave_A",
          "enter_A",
          "leave_A",
          "leave_S"
        ]
      }
    ]
  },
